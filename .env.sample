# ============================================================
# Nada - Environment Configuration Sample
# ============================================================
# Copy this file to .env and update the values as needed:
#   cp .env.sample .env
#
# Required variables do not have defaults and must be set.
# Optional variables have sample values and can be left as-is
# or modified based on your environment.
# ============================================================

# ------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------
# Logging level: debug, info, warning, error, critical
# Default: info
LOG_LEVEL=info

# ------------------------------------------------------------
# Celery Configuration (Required)
# ------------------------------------------------------------
# Redis URIs for Celery task queue and results backend
# Format: redis://[password@]host[:port]/db
CELERY_RESULT_URI=redis://localhost:6379/0
CELERY_BROKER_URI=redis://localhost:6379/0

# ------------------------------------------------------------
# Redis Cache Configuration (Required)
# ------------------------------------------------------------
# Redis server for caching (e.g., session data, temporary results)
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_CACHE_DBNUM=1

# ------------------------------------------------------------
# Redis Data Configuration (Required)
# ------------------------------------------------------------
# Redis server for persistent data storage (e.g., agent memory, semantic search)
REDIS_DATA_HOST=localhost
REDIS_DATA_PORT=6379
REDIS_DATA_DBNUM=2

# ------------------------------------------------------------
# SMTP Email Configuration (Optional)
# ------------------------------------------------------------
# SMTP server settings for sending emails (notifications, alerts)
# Set these if you need email functionality
# SMTP_HOST=smtp.example.com
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_password
# EMAILS_FROM_EMAIL=noreply@example.com
# SMTP_TLS=True
# SMTP_SSL=False
# SMTP_PORT=587

# ------------------------------------------------------------
# Telegram Bot Configuration (Optional)
# ------------------------------------------------------------
# Telegram bot token and chat ID for notifications
# Get a bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ------------------------------------------------------------
# LLM Provider Configuration (Optional)
# ------------------------------------------------------------
# For local LLM serving (e.g., Ollama, vLLM, llama.cpp)
# HOST_LLM_SERVER=http://localhost:8080

# For OpenRouter API (https://openrouter.ai/)
# Get an API key from your OpenRouter account dashboard
# OPENROUTER_API_KEY=sk-or-v1-your_api_key_here
